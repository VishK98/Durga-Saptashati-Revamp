<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve admin assets directly (not through public/)
    RewriteCond %{REQUEST_URI} ^/admin/assets/
    RewriteRule ^(.*)$ /$1 [L]

    # Rewrite /admin to /public/admin.php
    RewriteRule ^admin/?$ /public/admin.php [L]

    # Redirect everything else to the public folder
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_URI} !^/admin/assets/
    RewriteRule ^(.*)$ /public/$1 [L]
</IfModule>
